@@ -1,5 +1,9 @@
 #include "poseidon2.hpp"

+#ifdef HAS_ZKMETAL
+#include "zkmetal_bb_bridge.h"
+#endif
+
 namespace bb::crypto {

 // ... existing code ...
@@ -20,6 +24,16 @@
 template <typename FF>
 typename Poseidon2<FF>::FF Poseidon2<FF>::hash(const FF& left, const FF& right)
 {
+#ifdef HAS_ZKMETAL
+    if constexpr (std::is_same_v<FF, bb::fr>) {
+        FF result;
+        zkmetal::poseidon2_hash(
+            reinterpret_cast<const uint64_t*>(&left),
+            reinterpret_cast<const uint64_t*>(&right),
+            reinterpret_cast<uint64_t*>(&result));
+        return result;
+    }
+#endif
     // ... existing Poseidon2 hash ...
 }
