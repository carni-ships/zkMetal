diff --git a/cpp/src/barretenberg/crypto/poseidon2/poseidon2.cpp b/cpp/src/barretenberg/crypto/poseidon2/poseidon2.cpp
--- a/cpp/src/barretenberg/crypto/poseidon2/poseidon2.cpp
