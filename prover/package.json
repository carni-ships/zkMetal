{
  "name": "zkmetal",
  "version": "0.2.0",
  "description": "Generic Noir prover SDK — load any circuit, prove, verify, watch.",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./engine": "./src/engine.ts",
    "./watcher": "./src/watcher.ts",
    "./persistent-bb": "./src/persistent-bb.ts",
    "./adapters/persistia": "./src/adapters/persistia/index.ts"
  },
  "bin": {
    "zkmetal": "src/cli.ts"
  },
  "scripts": {
    "prove": "tsx src/cli.ts prove",
    "verify": "tsx src/cli.ts verify",
    "watch": "tsx src/cli.ts watch",
    "bench": "tsx src/cli.ts bench",
    "test": "node test/integration.mjs",
    "test:solidity": "cd ../test && forge test -vv"
  },
  "dependencies": {
    "@aztec/bb.js": "4.1.2",
    "@noir-lang/noir_js": "1.0.0-beta.19",
    "@noir-lang/types": "1.0.0-beta.19",
    "@noir-lang/acvm_js": "1.0.0-beta.19",
    "msgpackr": "^1.11.0"
  }
}
