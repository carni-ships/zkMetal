VestaFp vesta_pos_sbox(VestaFp x) {
    VestaFp x2 = vesta_mul(x, x);
    VestaFp x3 = vesta_mul(x2, x);
    VestaFp x4 = vesta_mul(x2, x2);
    return vesta_mul(x3, x4);
}

void vesta_pos_mds(thread VestaFp &s0, thread VestaFp &s1, thread VestaFp &s2) {
    VestaFp n0 = vesta_add(vesta_add(vesta_mul(VESTA_POS_MDS[0][0], s0),
                                      vesta_mul(VESTA_POS_MDS[0][1], s1)),
                            vesta_mul(VESTA_POS_MDS[0][2], s2));
    VestaFp n1 = vesta_add(vesta_add(vesta_mul(VESTA_POS_MDS[1][0], s0),
                                      vesta_mul(VESTA_POS_MDS[1][1], s1)),
                            vesta_mul(VESTA_POS_MDS[1][2], s2));
    VestaFp n2 = vesta_add(vesta_add(vesta_mul(VESTA_POS_MDS[2][0], s0),
                                      vesta_mul(VESTA_POS_MDS[2][1], s1)),
                            vesta_mul(VESTA_POS_MDS[2][2], s2));
    s0 = n0; s1 = n1; s2 = n2;
}

void vesta_poseidon_permute(thread VestaFp &s0, thread VestaFp &s1, thread VestaFp &s2) {
    for (uint r = 0; r < 55; r++) {
        s0 = vesta_pos_sbox(s0);
        s1 = vesta_pos_sbox(s1);
        s2 = vesta_pos_sbox(s2);
        vesta_pos_mds(s0, s1, s2);
        s0 = vesta_add(s0, VESTA_POS_RC[r][0]);
        s1 = vesta_add(s1, VESTA_POS_RC[r][1]);
        s2 = vesta_add(s2, VESTA_POS_RC[r][2]);
    }
}

VestaFp vesta_pos_hash_pair(VestaFp a, VestaFp b) {
    VestaFp s0 = a, s1 = b, s2 = vesta_zero();
    vesta_poseidon_permute(s0, s1, s2);
    return s0;
}

kernel void vesta_poseidon_permute_kernel(
    device const VestaFp* input   [[buffer(0)]],
    device VestaFp* output        [[buffer(1)]],
    constant uint& count          [[buffer(2)]],
    uint gid                      [[thread_position_in_grid]]
) {
    if (gid >= count) return;
    uint base = gid * 3;
    VestaFp s0 = input[base], s1 = input[base + 1], s2 = input[base + 2];
    vesta_poseidon_permute(s0, s1, s2);
    output[base] = s0; output[base + 1] = s1; output[base + 2] = s2;
}

kernel void vesta_poseidon_hash_pairs(
    device const VestaFp* input   [[buffer(0)]],
    device VestaFp* output        [[buffer(1)]],
    constant uint& count          [[buffer(2)]],
    uint gid                      [[thread_position_in_grid]]
) {
    if (gid >= count) return;
    output[gid] = vesta_pos_hash_pair(input[gid * 2], input[gid * 2 + 1]);
}

kernel void vesta_poseidon_sponge(
    device const VestaFp* inputs  [[buffer(0)]],
    device VestaFp* output        [[buffer(1)]],
    constant uint& count          [[buffer(2)]],
    constant uint& elementsPerHash [[buffer(3)]],
    uint gid                       [[thread_position_in_grid]]
) {
    if (gid >= count) return;
    uint base = gid * elementsPerHash;
    VestaFp s0 = vesta_zero(), s1 = vesta_zero(), s2 = vesta_zero();
    for (uint i = 0; i < elementsPerHash; i += 2) {
        s0 = vesta_add(s0, inputs[base + i]);
        if (i + 1 < elementsPerHash) s1 = vesta_add(s1, inputs[base + i + 1]);
        vesta_poseidon_permute(s0, s1, s2);
    }
    output[gid] = s0;
}
