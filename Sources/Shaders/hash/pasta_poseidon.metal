// S-box: x^7 = x^3 * x^4
PallasFp pallas_pos_sbox(PallasFp x) {
    PallasFp x2 = pallas_mul(x, x);
    PallasFp x3 = pallas_mul(x2, x);
    PallasFp x4 = pallas_mul(x2, x2);
    return pallas_mul(x3, x4);
}

// Full MDS matrix multiply
void pallas_pos_mds(thread PallasFp &s0, thread PallasFp &s1, thread PallasFp &s2) {
    PallasFp n0 = pallas_add(pallas_add(pallas_mul(PALLAS_POS_MDS[0][0], s0),
                                         pallas_mul(PALLAS_POS_MDS[0][1], s1)),
                              pallas_mul(PALLAS_POS_MDS[0][2], s2));
    PallasFp n1 = pallas_add(pallas_add(pallas_mul(PALLAS_POS_MDS[1][0], s0),
                                         pallas_mul(PALLAS_POS_MDS[1][1], s1)),
                              pallas_mul(PALLAS_POS_MDS[1][2], s2));
    PallasFp n2 = pallas_add(pallas_add(pallas_mul(PALLAS_POS_MDS[2][0], s0),
                                         pallas_mul(PALLAS_POS_MDS[2][1], s1)),
                              pallas_mul(PALLAS_POS_MDS[2][2], s2));
    s0 = n0; s1 = n1; s2 = n2;
}

// 55 full rounds: sbox -> MDS -> addRC
void pallas_poseidon_permute(thread PallasFp &s0, thread PallasFp &s1, thread PallasFp &s2) {
    for (uint r = 0; r < 55; r++) {
        s0 = pallas_pos_sbox(s0);
        s1 = pallas_pos_sbox(s1);
        s2 = pallas_pos_sbox(s2);
        pallas_pos_mds(s0, s1, s2);
        s0 = pallas_add(s0, PALLAS_POS_RC[r][0]);
        s1 = pallas_add(s1, PALLAS_POS_RC[r][1]);
        s2 = pallas_add(s2, PALLAS_POS_RC[r][2]);
    }
}

PallasFp pallas_pos_hash_pair(PallasFp a, PallasFp b) {
    PallasFp s0 = a, s1 = b, s2 = pallas_zero();
    pallas_poseidon_permute(s0, s1, s2);
    return s0;
}

// --- Pallas GPU kernels ---

kernel void pallas_poseidon_permute_kernel(
    device const PallasFp* input   [[buffer(0)]],
    device PallasFp* output        [[buffer(1)]],
    constant uint& count           [[buffer(2)]],
    uint gid                       [[thread_position_in_grid]]
) {
    if (gid >= count) return;
    uint base = gid * 3;
    PallasFp s0 = input[base], s1 = input[base + 1], s2 = input[base + 2];
    pallas_poseidon_permute(s0, s1, s2);
    output[base] = s0; output[base + 1] = s1; output[base + 2] = s2;
}

kernel void pallas_poseidon_hash_pairs(
    device const PallasFp* input   [[buffer(0)]],
    device PallasFp* output        [[buffer(1)]],
    constant uint& count           [[buffer(2)]],
    uint gid                       [[thread_position_in_grid]]
) {
    if (gid >= count) return;
    output[gid] = pallas_pos_hash_pair(input[gid * 2], input[gid * 2 + 1]);
}

kernel void pallas_poseidon_sponge(
    device const PallasFp* inputs  [[buffer(0)]],
    device PallasFp* output        [[buffer(1)]],
    constant uint& count           [[buffer(2)]],
    constant uint& elementsPerHash [[buffer(3)]],
    uint gid                       [[thread_position_in_grid]]
) {
    if (gid >= count) return;
    uint base = gid * elementsPerHash;
    PallasFp s0 = pallas_zero(), s1 = pallas_zero(), s2 = pallas_zero();
    for (uint i = 0; i < elementsPerHash; i += 2) {
        s0 = pallas_add(s0, inputs[base + i]);
        if (i + 1 < elementsPerHash) s1 = pallas_add(s1, inputs[base + i + 1]);
        pallas_poseidon_permute(s0, s1, s2);
    }
    output[gid] = s0;
}

